@page "/checkout"
@using System.Globalization
@using System.ComponentModel.DataAnnotations
@using API.Models.DTO
@using API.Models.DTO.BanHang
@using BlazorKhachHang.Service.IService
@using Data.Models
@using static BlazorKhachHang.Components.Pages.TaiKhoan.KhachHang
@inject IXuLyDiaChi xuLyDiaChi
@inject NavigationManager Nav
@inject IHoaDonService HoaDonService
@inject IJSRuntime JS
@inject IGioHangService GioHangService
@inject IVoucherService VoucherService
@inject HttpClient Http
<PageTitle>Checkout - Đặt hàng</PageTitle>

<style>
    body {
        background: #fcfcfa;
        font-family: 'Segoe UI', Arial, sans-serif;
        color: #222;
    }

    .container {
        max-width: 1200px;
        margin: 30px auto;
        padding: 0 20px;
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 30px;
        align-items: flex-start;
    }

    .checkout-form {
        background: #fff;
        padding: 30px 30px 20px 30px;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
    }

    .form-title {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 18px;
        color: #222;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .freeship-box {
        background: #fff8e1;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 14px;
    }

    .text-success {
        color: #28a745;
        font-weight: 500;
    }

    .text-warning {
        color: #ff9800;
    }

    .address-btn {
        background: #3498db;
        color: white;
        border: none;
        padding: 7px 18px;
        border-radius: 6px;
        font-size: 13px;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .address-btn:hover {
            background: #2980b9;
            transform: translateY(-1px);
        }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 0;
    }

    .form-group {
        margin-bottom: 0;
    }

        .form-group.full-width {
            grid-column: 1 / -1;
            margin-top: 15px;
        }

    .form-row.address-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-bottom: 0;
    }

    label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
        color: #222;
        font-size: 15px;
    }

    .required {
        color: #e74c3c;
        margin-right: 3px;
    }

    input,
    select,
    textarea {
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
        padding: 11px 12px;
        border: 2px solid #e1e8ed;
        border-radius: 8px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: white;
        height: 44px;
        appearance: none;
    }

        input:focus,
        select:focus,
        textarea:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 0 2px rgba(52, 152, 219, 0.08);
        }

    textarea {
        height: auto;
        min-height: 44px;
        resize: vertical;
    }

    .payment-section {
        margin-top: 18px;
        padding-top: 18px;
        border-top: 2px solid #f2f2f2;
    }

    .payment-title {
        font-size: 17px;
        font-weight: 600;
        margin-bottom: 12px;
        color: #222;
    }

    .payment-options {
        display: flex;
        gap: 15px;
    }

    .payment-option {
        flex: 1 1 0;
        border: 2px solid #e1e8ed;
        border-radius: 10px;
        padding: 14px 18px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 12px;
        background: #fff;
        min-width: 0;
        justify-content: center;
        height: 60px;
        box-sizing: border-box;
    }

        .payment-option:hover {
            border-color: #3498db;
            background: #f8fafc;
        }

        .payment-option.selected {
            border-color: #3498db;
            background: #e3f2fd;
        }

    .payment-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: white;
        font-size: 20px;
        flex-shrink: 0;
    }

        .payment-icon.cod {
            background: #ff9800;
        }

        .payment-icon.vnpay {
            background: linear-gradient(45deg, #ff6b6b, #4ecdc4);
        }

    .submit-btn {
        width: 100%;
        background: #222;
        color: white;
        border: none;
        padding: 15px;
        border-radius: 10px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        margin-top: 22px;
        transition: all 0.3s ease;
        letter-spacing: 1px;
    }

        .submit-btn:hover {
            background: #444;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.15);
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #8e44ad;
        text-decoration: none;
        margin-top: 18px;
        font-weight: 500;
        font-size: 15px;
        transition: all 0.3s ease;
    }

        .back-link:hover {
            color: #9b59b6;
            transform: translateX(-3px);
        }

    .order-summary {
        background: #fff;
        padding: 25px 20px;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
        height: fit-content;
        position: sticky;
        top: 20px;
        min-width: 340px;
    }

    .product-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px 0;
        border-bottom: 1px solid #ecf0f1;
        position: relative;
    }

    .product-image {
        width: 70px;
        height: 70px;
        border-radius: 8px;
        object-fit: cover;
    }

    .product-info h4 {
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 3px;
        color: #222;
    }

    .product-size {
        background: #f39c12;
        color: white;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
        margin-top: 2px;
        display: inline-block;
    }

    .product-price {
        font-size: 15px;
        font-weight: 700;
        color: #e74c3c;
        margin-left: auto;
    }

    .quantity-badge {
        position: absolute;
        top: 8px;
        left: -10px;
        background: #ff9800;
        color: white;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: bold;
    }

    .discount-section {
        margin: 18px 0;
        display: flex;
        gap: 10px;
    }

    .discount-input {
        flex: 1;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 15px;
    }

    .apply-btn {
        background: #222;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        font-size: 15px;
        transition: all 0.3s ease;
    }

        .apply-btn:hover {
            background: #444;
        }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin: 10px 0;
        font-size: 14px;
    }

        .summary-row.shipping {
            color: #e74c3c;
        }

        .summary-row.discount {
            color: #27ae60;
        }

        .summary-row.total {
            border-top: 2px solid #ecf0f1;
            padding-top: 15px;
            margin-top: 20px;
            font-size: 18px;
            font-weight: 700;
            color: #e74c3c;
        }

    .delivery-date {
        text-align: center;
        margin: 15px 0;
        font-size: 14px;
        color: #7f8c8d;
    }

        .delivery-date strong {
            color: #e74c3c;
        }

    .alert {
        padding: 15px;
        margin: 15px 0;
        border-radius: 8px;
        font-weight: 500;
    }

    .alert-success {
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
        color: #155724;
    }

    .alert-info {
        background-color: #cce7ff;
        border: 1px solid #b3d9ff;
        color: #004085;
    }

    input[type="radio"] {
        width: auto;
        height: auto;
        padding: 0;
        border: none;
        appearance: auto;
        transform: scale(1.2);
        cursor: pointer;
    }
</style>

<div class="container">
    <div class="checkout-form">
        <div class="form-title">
            Thông tin giao hàng
            <button type="button" class="address-btn" @onclick="() => IsAddressModalVisible = true">CHỌN ĐỊA CHỈ</button>
        </div>

        <EditForm Model="checkoutModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="form-row">
                <div class="form-group">
                    <label><span class="required">*</span>Họ và tên</label>
                    <InputText @bind-Value="checkoutModel.FullName" required />
                    <ValidationMessage For="@(() => checkoutModel.FullName)" />
                </div>
                <div class="form-group">
                    <label><span class="required">*</span>Số điện thoại</label>
                    <InputText @bind-Value="checkoutModel.PhoneNumber" required />
                    <ValidationMessage For="@(() => checkoutModel.PhoneNumber)" />
                </div>
            </div>

            <div class="form-row address-row">
                <div class="form-group">
                    <label><span class="required">*</span>Tỉnh/thành phố</label>
                    <InputSelect Value="@Tinh"
                                 ValueChanged="@((string value) => OnTinhChanged(value))"
                                 ValueExpression="() => Tinh">
                        <option value="">Chọn Tỉnh</option>
                        @foreach (var t in TinhThanh)
                        {
                            <option value="@t.Ten">@t.Ten</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="@(() => checkoutModel.Province)" />
                </div>
                <div class="form-group">
                    <label><span class="required">*</span>Quận/huyện</label>
                    <InputSelect Value="@Huyen"
                                 ValueChanged="@((string value) => OnHuyenChanged(value))"
                                 ValueExpression="() => Huyen">
                        <option value="">Chọn quận/huyện</option>
                        @foreach (var h in HuyenXa)
                        {
                            <option value="@h.Ten">@h.Ten</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => checkoutModel.District)" />
                </div>
                <div class="form-group">
                    <label><span class="required">*</span>Xã/thị trấn</label>
                    <InputSelect Value="@Phuong"
                                 ValueChanged="@((string value) => OnXaPhuongChanged(value))"
                                 ValueExpression="() => Phuong">
                        <option value="">Chọn xã/thị trấn</option>
                        @foreach (var x in XaPhuong)
                        {
                            <option value="@x.Ten">@x.Ten</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => checkoutModel.Ward)" />
                </div>
            </div>

            <div class="form-group full-width">
                <label><span class="required">*</span>Địa chỉ cụ thể</label>
                <InputText @bind-Value="checkoutModel.SpecificAddress" required />
                <ValidationMessage For="@(() => checkoutModel.SpecificAddress)" />
            </div>

            <div class="form-group full-width">
                <label>Ghi chú</label>
                <InputTextArea @bind-Value="checkoutModel.Notes" placeholder="Nhập ghi chú đơn hàng..." />
            </div>

            <div class="payment-section">
                <div class="payment-title">Phương thức thanh toán</div>
                <div class="payment-options">
                    <div class="payment-option @(checkoutModel.PaymentMethod == "cod" ? "selected" : "")"
                         @onclick='() => SelectPayment("cod")'>
                        <div class="payment-icon cod">📦</div>
                        <span>Thanh toán khi nhận hàng</span>
                    </div>
                    <div class="payment-option @(checkoutModel.PaymentMethod == "vnpay" ? "selected" : "")"
                         @onclick='() => SelectPayment("vnpay")'>
                        <div class="payment-icon vnpay">💳</div>
                        <span>Thanh toán ngay</span>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            @if (!string.IsNullOrEmpty(infoMessage))
            {
                <div class="alert alert-info">@infoMessage</div>
            }

            <button type="submit" class="submit-btn" disabled="@isSubmitting">
                HOÀN THÀNH ĐẶT HÀNG
            </button>
        </EditForm>

        <a href="/cart" class="back-link">
            ← Quay lại giỏ hàng
        </a>
    </div>

    <div class="order-summary">

        @* ====== MUA NGAY ====== *@
        @if (isBuyNow && buyNowItem != null)
        {
            <div class="product-item">
                <div class="quantity-badge">@buyNowItem.SoLuong</div>

                <img src="@GetFullImageUrl(buyNowItem.HinhAnh)"
                     class="product-image"
                     onerror="this.onerror=null;this.src='/images/no-image.png';" />

                <div class="product-info">
                    <h4>@buyNowItem.TenGiay</h4>

                    <div class="product-size">
                        Size: @buyNowItem.Size
                    </div>

                    @if (!string.IsNullOrEmpty(buyNowItem.MauSac))
                    {
                        <div class="product-size" style="background:#3498db;margin-top:4px">
                            Màu: @buyNowItem.MauSac
                        </div>
                    }
                </div>

                <div class="product-price">
                    @((buyNowItem.Gia).ToString("N0", CultureInfo.GetCultureInfo("vi-VN"))) VNĐ
                </div>
            </div>
        }
        @* ====== THANH TOÁN TỪ GIỎ HÀNG ====== *@
        else if (checkoutItems.Any())
        {
            @foreach (var item in checkoutItems)
            {
                <div class="product-item">
                    <div class="quantity-badge">@item.SoLuong</div>

                    <img src="@GetFullImageUrl(item.HinhAnh)"
                         class="product-image"
                         onerror="this.onerror=null;this.src='/images/no-image.png';" />

                    <div class="product-info">
                        <h4>@item.TenGiay</h4>

                        <div class="product-size">
                            Size: @item.Size
                        </div>

                        @if (!string.IsNullOrEmpty(item.MauSac))
                        {
                            <div class="product-size" style="background:#3498db;margin-top:4px">
                                Màu: @item.MauSac
                            </div>
                        }
                    </div>

                    <div class="product-price">
                        @item.Gia.ToString("N0", CultureInfo.GetCultureInfo("vi-VN")) VNĐ
                    </div>
                </div>
            }
        }

        <div class="discount-section">
            <div class="discount-wrapper">
                <input type="text"
                       placeholder="Mã giảm giá"
                       class="discount-input"
                       @bind="discountCode"
                       @bind:event="oninput">

                <button type="button"
                        class="apply-btn"
                        @onclick="() => showVoucherModal = !showVoucherModal"
                        style="@(selectedVoucherId != null ? "background:#3498db" : "")">
                    @(selectedVoucherId == null ? "Chọn" : "Đổi")
                </button>
            </div>

            @* ĐÂY LÀ ĐOẠN BẠN CẦN THAY THẾ/CHÈN VÀO *@
            @if (showVoucherModal)
            {
                <div class="voucher-dropdown">
                    <div class="form-title" style="font-size: 15px; margin-bottom: 10px; display: flex; justify-content: space-between;">
                        Chọn mã giảm giá
                        <span style="cursor:pointer; color:#999" @onclick="() => showVoucherModal = false">×</span>
                    </div>

                    <div class="voucher-list" style="max-height: 250px; overflow-y: auto;">
                        @if (vouchers == null || !vouchers.Any())
                        {
                            <p style="font-size:13px; color:#999; text-align:center">Không có mã giảm giá</p>
                        }
                        else
                        {
                            @foreach (var v in vouchers)
                            {
                                var isDisabled = SubTotal < (decimal)v.DieuKienToiThieu;

                                <div class="voucher-item @(selectedVoucherId == v.VoucherId ? "active-voucher" : "")"
                                     style="
                                     display:flex;
                                     align-items:center;
                                     gap:10px;
                                     padding:10px;
                                     border-bottom:1px solid #eee;
                                     border-left:4px solid #3498db;
                                     margin-bottom:5px;
                                     cursor:@(isDisabled ? "not-allowed" : "pointer");
                                     opacity:@(isDisabled ? "0.4" : "1");
                                 "
                                     @onclick="() => { if (!isDisabled) ToggleVoucher(v); }">

                                    <input type="radio"
                                           checked="@(selectedVoucherId == v.VoucherId)"
                                           disabled="@isDisabled"
                                           @onclick:stopPropagation />

                                    <div style="flex:1">
                                        <div style="font-weight:600">
                                            @v.TenVoucher
                                        </div>

                                        <div style="font-size:12px;color:#27ae60">
                                            Giảm:
                                            @(v.PhanTram > 0
                                                                            ? $"{v.PhanTram}%"
                                                                            : $"{v.SoTienGiam:N0} VNĐ")
                            </div>

                                        <div style="font-size:11px;color:#999">
                                            Đơn tối thiểu:
                                            @v.DieuKienToiThieu.ToString("N0") VNĐ
                                        </div>

                            @if (isDisabled)
                                        {
                                            <div style="color:red;font-size:11px">
                                                Cần thêm
                                                @Math.Max(
                                                0, ((decimal)v.DieuKienToiThieu - SubTotal)  ).ToString("N0")  VNĐ
                            </div>
                                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <button type="button" class="apply-btn" style="width: 100%; margin-top: 10px; background: #f8f9fa; color: #333; border: 1px solid #ddd;"
                            @onclick="() => showVoucherModal = false">
                        Đóng
                    </button>
                </div>
            }
        </div>

        <div class="summary-row shipping">
            <span>Phí vận chuyển</span>
            <span>@shippingFee.ToString("N0", CultureInfo.GetCultureInfo("vi-VN")) VNĐ</span>
        </div>

        <div class="summary-row discount">
            <span>Giảm giá</span>
            <span>@discountAmount.ToString("N0", CultureInfo.GetCultureInfo("vi-VN"))  VNĐ</span>
        </div>

        <div class="delivery-date">
            Ngày nhận dự kiến:
            <strong>@deliveryDate.ToString("dd-MM-yyyy")</strong>
        </div>

        <div class="summary-row total">
            <span>Tổng số tiền</span>
            <span>@TotalAmount.ToString("N0", CultureInfo.GetCultureInfo("vi-VN")) VNĐ</span>
        </div>

    </div>
    <div class="freeship-box mt-2">
        @if (SubTotal < 2000000)
        {
            <small class="text-warning">
                🚚 Mua thêm <b>@(string.Format("{0:N0}", 2000000 - SubTotal))đ</b> để được miễn phí vận chuyển
            </small>
        }
        else
        {
            <small class="text-success">
                🎉 Bạn đã được miễn phí vận chuyển
            </small>
        }
    </div>
</div>

<ChonDiaChi IsAddressModalVisible="@IsAddressModalVisible"
            OnAddressSelected="HandleAddressSelected"
            OnClose="CloseAddressModal" />

@code {
    private string BaseApiUrl = "https://localhost:7246";
    private CheckoutModel checkoutModel = new();
    private ProductItem product = new();
    private string discountCode = "";
    private decimal shippingFee = 0;
    private decimal discountAmount = 0m;
    private DateTime deliveryDate;
    private string successMessage = "";
    private string infoMessage = "";
    private bool IsAddressModalVisible = false;
    private List<DiaChi> TinhThanh = new();
    private List<DiaChi> HuyenXa = new();
    private List<DiaChi> XaPhuong = new();
    private GioHangDTO? gioHang;
    private BuyNowItem? buyNowItem;
    private bool isBuyNow = false;
    private List<GioHangChiTietDTO> checkoutItems = new();
    private bool isSubmitting = false;
    private Guid? appliedVoucherId;
    private List<Voucher> vouchers = new();
    private bool showVoucherModal = false;
    private Guid? selectedVoucherId;


    private bool _loaded = false;

    protected override async Task OnInitializedAsync()
    {
        TinhThanh = await xuLyDiaChi.ParseDiaChiAsync("wwwroot/Files/ThanhPho.txt");
        deliveryDate = DateTime.Now.AddDays(3);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_loaded)
        {
            _loaded = true;
            // load voucher công khai
            vouchers = (await VoucherService.GetAll())
                .Where(v =>
                    v.TrangThai &&
                    v.NgayBatDau <= DateTime.Now &&
                    v.NgayKetThuc >= DateTime.Now &&
                    v.SoLuong > 0)
                .ToList();

            var buyNowJson = await JS.InvokeAsync<string>("localStorage.getItem", "buyNowItem");
            var checkoutJson = await JS.InvokeAsync<string>("localStorage.getItem", "checkoutItems");

            if (!string.IsNullOrEmpty(buyNowJson))
            {
                buyNowItem = System.Text.Json.JsonSerializer.Deserialize<BuyNowItem>(buyNowJson);
                isBuyNow = true;
            }
            else if (!string.IsNullOrEmpty(checkoutJson))
            {
                checkoutItems = System.Text.Json.JsonSerializer
                    .Deserialize<List<GioHangChiTietDTO>>(checkoutJson) ?? new();
            }
            else
            {
                var khachHangIdStr =
                    await JS.InvokeAsync<string>("localStorage.getItem", "khachHangId");

                if (!string.IsNullOrEmpty(khachHangIdStr))
                {
                    gioHang = await GioHangService.LayTheoTaiKhoanAsync(
                        Guid.Parse(khachHangIdStr)
                    );
                }
            }

            StateHasChanged();
        }
    }

    private string Tinh = "";
    private async Task OnTinhChanged(string value)
    {
        Tinh = value;

        var tinh = TinhThanh.FirstOrDefault(t => t.Ten == Tinh);
        HuyenXa = tinh?.Con ?? new();
        XaPhuong = new();

        Huyen = "";
        Phuong = "";
        checkoutModel.Province = Tinh;

        // ✅ QUAN TRỌNG
        shippingFee = CalculateShippingFee(Tinh);
    }


    private string Huyen = "";
    void OnHuyenChanged(string value)
    {
        Huyen = value;

        var huyen = HuyenXa.FirstOrDefault(h => h.Ten == Huyen);
        XaPhuong = huyen?.Con ?? new();

        Phuong = "";
        checkoutModel.District = Huyen;
    }

    private string Phuong = "";
    void OnXaPhuongChanged(string value)
    {
        Phuong = value;
        checkoutModel.Ward = Phuong;
    }


    private void SelectPayment(string paymentType)
    {
        checkoutModel.PaymentMethod = paymentType;
        StateHasChanged();
    }



    private async Task ApplyDiscount()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(discountCode))
                return;

            var voucher = await VoucherService.GetByCodeAsync(discountCode);

            if (voucher == null)
            {
                discountAmount = 0;
                appliedVoucherId = null; // reset
                infoMessage = "❌ Voucher không tồn tại";
                return;
            }

            var tongTien = TotalAmount;

            if (DateTime.Now < voucher.NgayBatDau || DateTime.Now > voucher.NgayKetThuc)
            {
                discountAmount = 0;
                appliedVoucherId = null;
                infoMessage = "❌ Voucher hết hạn";
                return;
            }

            if (tongTien < (decimal)voucher.DieuKienToiThieu)
            {
                discountAmount = 0;
                appliedVoucherId = null;
                infoMessage = $"❌ Đơn tối thiểu {voucher.DieuKienToiThieu:N0} VNĐ";
                return;
            }

            decimal discount = 0;

            if (voucher.PhanTram > 0)
            {
                discount = tongTien * (decimal)voucher.PhanTram / 100;
            }
            else
            {
                discount = (decimal)voucher.SoTienGiam;
            }

            discount = Math.Min(discount, (decimal)voucher.GiamToiDa);

            discountAmount = discount;

            // ✅ QUAN TRỌNG: gán voucher đã chọn
            appliedVoucherId = voucher.VoucherId;

            infoMessage = $"✅ Áp dụng voucher {voucher.TenVoucher} thành công";
            successMessage = "";

            StateHasChanged();
        }
        catch
        {
            discountAmount = 0;
            appliedVoucherId = null;
            infoMessage = "❌ Lỗi khi áp dụng voucher";
        }
    }

    private decimal SubTotal =>
    (isBuyNow && buyNowItem != null
        ? buyNowItem.SoLuong * buyNowItem.Gia
        : (checkoutItems.Any()
            ? checkoutItems.Sum(x => x.SoLuong * x.Gia)
            : gioHang?.DanhSachChiTiet?
                .Where(x => x.IsSelected)
                .Sum(x => x.SoLuong * x.Gia) ?? 0));

    private decimal TotalAmount =>
        SubTotal + shippingFee - discountAmount;

    private async Task HandleSubmit()
    {
        var confirm = await JS.InvokeAsync<bool>("confirm",
            $"Tổng tiền: {TotalAmount:N0} VNĐ\n\nBạn có chắc muốn đặt hàng không?");

        if (!confirm)
        {
            infoMessage = "❌ Bạn đã hủy đặt hàng.";
            return;
        }

        isSubmitting = true;
        var khachHangIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "khachHangId");

        if (string.IsNullOrEmpty(khachHangIdStr))
        {
            infoMessage = "❌ Không xác định được khách hàng";
            isSubmitting = false; // Đừng quên mở lại nút bấm nếu lỗi
            return;
        }

        var request = new DatHang.DatHangRequest
        {
            KhachHangId = Guid.Parse(khachHangIdStr),
            TenNguoiNhan = checkoutModel.FullName,
            SoDienThoai = checkoutModel.PhoneNumber,
            DiaChi = $"{checkoutModel.SpecificAddress}, {checkoutModel.Ward}, {checkoutModel.District}, {checkoutModel.Province}",
            PhiShip = (float)shippingFee,
            TongTienSauKhiGiam = (float)TotalAmount,
            VoucherId = appliedVoucherId,
            GhiChu = checkoutModel.Notes,
            HinhThucThanhToanId = checkoutModel.PaymentMethod == "cod"
                ? Guid.Parse("aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa")
                : Guid.Parse("bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"),

            Items = isBuyNow && buyNowItem != null
                ? new List<DatHang.DatHangItem>
                  {
                  new DatHang.DatHangItem
                  {
                      GiayChiTietId = buyNowItem.GiayChiTietId,
                      SoLuong = buyNowItem.SoLuong,
                      Gia = buyNowItem.Gia
                  }
                  }
                : (checkoutItems.Any() ? checkoutItems : gioHang!.DanhSachChiTiet.Where(x => x.IsSelected))
                    .Select(x => new DatHang.DatHangItem
                    {
                        GioHangChiTietId = x.GioHangChiTietId,
                        GiayChiTietId = x.GiayChiTietId,
                        SoLuong = x.SoLuong,
                        Gia = x.Gia
                    })
                    .ToList()
        };

        if (!request.Items.Any())
        {
            infoMessage = "❌ Bạn chưa chọn sản phẩm để thanh toán";
            isSubmitting = false;
            return;
        }

        var ok = await HoaDonService.DatHangAsync(request);

        if (ok)
        {
            // ============================================================
            // CẬP NHẬT SỐ LƯỢNG VÀO SERVICE TRƯỚC KHI RỜI TRANG
            // ============================================================

            // Xóa các bản lưu tạm local
            await JS.InvokeVoidAsync("localStorage.removeItem", "buyNowItem");
            await JS.InvokeVoidAsync("localStorage.removeItem", "checkoutItems");

            successMessage = "Đặt hàng thành công";
            StateHasChanged(); // Render lại để hiện message thành công

            await Task.Delay(1200); // Đợi một chút cho khách hàng kịp đọc thông báo

            // Chuyển hướng sang trang đơn hàng
            Nav.NavigateTo("/Oder", true);
        }
        else
        {
            infoMessage = "Đặt hàng thất bại.";
            isSubmitting = false;
        }
    }
    private decimal CalculateShippingFee(string tinh)
    {
        // ✅ FREE SHIP nếu >= 2 triệu
        if (SubTotal >= 2000000)
        {
            deliveryDate = DateTime.Now.AddDays(2); // vẫn có ngày giao
            return 0;
        }

        if (string.IsNullOrEmpty(tinh))
            return 0;

        string shopLocation = "Hà Nội";

        // 🟢 Nội thành
        if (tinh.Contains(shopLocation))
        {
            deliveryDate = DateTime.Now.AddDays(1);
            return 20000;
        }

        var mienBac = new List<string>
    {
        "Hải Phòng", "Bắc Ninh", "Hà Nam", "Hải Dương", "Hưng Yên",
        "Nam Định", "Ninh Bình", "Thái Bình", "Vĩnh Phúc", "Lào Cai", "Yên Bái",
        "Điện Biên", "Hòa Bình", "Lai Châu", "Sơn La", "Hà Giang", "Cao Bằng",
        "Bắc Kạn", "Lạng Sơn", "Tuyên Quang", "Thái Nguyên", "Phú Thọ", "Bắc Giang", "Quảng Ninh"
    };

        var mienTrung = new List<string>
    {
        "Thanh Hóa", "Nghệ An", "Hà Tĩnh", "Quảng Bình", "Quảng Trị", "Thừa Thiên Huế",
        "Đà Nẵng", "Quảng Nam", "Quảng Ngãi", "Bình Định", "Phú Yên", "Khánh Hòa",
        "Ninh Thuận", "Bình Thuận", "Kon Tum", "Gia Lai", "Đắc Lắk", "Đắc Nông", "Lâm Đồng"
    };

        var mienNam = new List<string>
    {
        "TP Hồ Chí Minh", "Bà Rịa - Vũng Tàu", "Bình Dương", "Bình Phước", "Đồng Nai", "Tây Ninh",
        "An Giang", "Bạc Liêu", "Bến Tre", "Cà Mau", "Cần Thơ", "Đồng Tháp", "Hậu Giang",
        "Kiên Giang", "Long An", "Sóc Trăng", "Tiền Giang", "Trà Vinh", "Vĩnh Long"
    };

        // 🔴 Nội miền Bắc
        if (mienBac.Any(x => tinh.Contains(x)))
        {
            deliveryDate = DateTime.Now.AddDays(2);
            return 28000;
        }

        // 🟡 Miền Trung
        if (mienTrung.Any(x => tinh.Contains(x)))
        {
            deliveryDate = DateTime.Now.AddDays(3);
            return 35000;
        }

        // 🔵 Miền Nam
        if (mienNam.Any(x => tinh.Contains(x)))
        {
            deliveryDate = DateTime.Now.AddDays(4);
            return 45000;
        }

        deliveryDate = DateTime.Now.AddDays(4);
        return 40000;
    }
    private async Task HandleAddressSelected(DiaChiKhachHang diaChi)
    {
        var khachHangIdStr =
            await JS.InvokeAsync<string>("localStorage.getItem", "khachHangId");

        if (!string.IsNullOrEmpty(khachHangIdStr))
        {
            var kh = await Http.GetFromJsonAsync<KhachHangModel>(
                $"api/KhachHang/{Guid.Parse(khachHangIdStr)}");

            if (kh != null)
            {
                checkoutModel.FullName = kh.HoTen;
                checkoutModel.PhoneNumber = kh.SoDienThoai; // 🔥 CHUẨN 100%
            }
        }

        // ===== địa chỉ =====
        checkoutModel.SpecificAddress = diaChi.DiaChiCuThe;

        Tinh = diaChi.ThanhPho;
        Huyen = diaChi.QuanHuyen;
        Phuong = diaChi.PhuongXa;

        var tinh = TinhThanh.FirstOrDefault(x => x.Ten == Tinh);
        HuyenXa = tinh?.Con ?? new();

        var huyen = HuyenXa.FirstOrDefault(x => x.Ten == Huyen);
        XaPhuong = huyen?.Con ?? new();

        checkoutModel.Province = Tinh;
        checkoutModel.District = Huyen;
        checkoutModel.Ward = Phuong;
        shippingFee = CalculateShippingFee(Tinh);

        StateHasChanged();
    }

