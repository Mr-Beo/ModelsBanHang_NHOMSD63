    private async Task ToggleVoucher(Voucher v)
    {
        var tongTien = SubTotal;

        if (tongTien < (decimal)v.DieuKienToiThieu)
        {
            infoMessage =
                $"❌ Đơn hàng tối thiểu {v.DieuKienToiThieu:N0} VNĐ";

            return;
        }

        if (selectedVoucherId == v.VoucherId)
        {
            // bỏ chọn
            selectedVoucherId = null;
            appliedVoucherId = null;
            discountCode = "";
            discountAmount = 0;

            infoMessage = "Đã bỏ voucher";
        }
        else
        {
            selectedVoucherId = v.VoucherId;
            appliedVoucherId = v.VoucherId;

            decimal discount = 0;

            if (v.PhanTram > 0)
            {
                discount = tongTien * (decimal)v.PhanTram / 100;
            }
            else
            {
                discount = (decimal)v.SoTienGiam;
            }

            discount = Math.Min(
                discount,
                (decimal)v.GiamToiDa);

            discountAmount = discount;

            infoMessage =
                $"✅ Đã áp dụng {v.TenVoucher}";
        }

        showVoucherModal = false;

        StateHasChanged();
    }

    private string GetFullImageUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "/images/no-image.png";

        if (path.StartsWith("http"))
            return path;

        return $"{BaseApiUrl.TrimEnd('/')}/{path.TrimStart('/')}";
    }

