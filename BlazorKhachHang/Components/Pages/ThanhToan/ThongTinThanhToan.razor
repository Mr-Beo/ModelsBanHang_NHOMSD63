    private void ParseAddress(string fullAddress)
    {
        var parts = fullAddress.Split(',');

        if (parts.Length >= 4)
        {
            Phuong = parts[1].Trim();
            Huyen = parts[2].Trim();
            Tinh = parts[3].Trim();
        }
    }
