@using API.Models.DTO
@using Microsoft.AspNetCore.Components.Forms

@if (IsVisible)
{
    <!-- BACKDROP -->
    <div class="modal-backdrop fade show"></div>

    <!-- MODAL -->
    <div class="modal show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">

                <!-- HEADER -->
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        @(IsEdit ? "✏️ Sửa màu sắc" : "➕ Thêm màu sắc")
                    </h5>
                    <button class="btn-close btn-close-white" @onclick="Close"></button>
                </div>

                <!-- BODY -->
                <EditForm Model="FormData" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="modal-body">

                        <!-- TÊN -->
                        <div class="mb-3">
                            <label class="form-label">Tên màu</label>
                            <InputText class="form-control" @bind-Value="FormData.TenMau" />
                            <ValidationMessage For="@(() => FormData.TenMau)" />
                        </div>

                        <!-- COLOR -->
                        <div class="mb-3">
                            <label class="form-label">Mã màu</label>

                            <div class="d-flex align-items-center gap-2">
                                <input type="color"
                                       class="form-control form-control-color"
                                       @bind="FormData.Color" />

                                <!-- preview -->
                                <div style="width:30px;height:30px;border-radius:50%;
                                            background:@FormData.Color;
                                            border:1px solid #ccc">
                                </div>
                            </div>
                        </div>

                        <!-- MÔ TẢ -->
                        <div class="mb-3">
                            <label class="form-label">Mô tả</label>
                            <textarea class="form-control" @bind="FormData.MoTa"></textarea>
                        </div>

                        <!-- TRẠNG THÁI -->
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="FormData.TrangThai" />
                            <label class="form-check-label">Hiển thị</label>
                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="Close">
                            Đóng
                        </button>

                        <button type="submit" class="btn btn-warning">
                            @(IsEdit ? "Lưu" : "Thêm")
                        </button>
                    </div>

                </EditForm>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public MauSacDTO FormData { get; set; } = new();
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public bool IsEdit { get; set; }

    private async Task HandleSubmit()
    {
        if (OnSubmit.HasDelegate)
            await OnSubmit.InvokeAsync();
    }

    private async Task Close()
    {
        if (OnClose.HasDelegate)
            await OnClose.InvokeAsync();
    }
}