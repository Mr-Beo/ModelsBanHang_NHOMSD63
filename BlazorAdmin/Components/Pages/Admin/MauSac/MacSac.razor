@page "/MauSac"
@using API.Models.DTO
@inject IMauSacService mauSacService
@inject IJSRuntime JS

<h4 class="mb-3">🎨 Quản lý màu sắc</h4>

<!-- DASHBOARD -->
<div class="row mb-4 text-center">
    <div class="col-md-4">
        <div class="bg-light border rounded p-4 shadow-sm">
            <h6>Tổng màu</h6>
            <h4>@danhSach.Count</h4>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-light border rounded p-4 shadow-sm">
            <h6>Đang hoạt động</h6>
            <h4>@danhSach.Count(x => x.TrangThai)</h4>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bg-light border rounded p-4 shadow-sm">
            <h6>Ngừng hoạt động</h6>
            <h4>@danhSach.Count(x => !x.TrangThai)</h4>
        </div>
    </div>
</div>

<!-- TABLE -->
<div class="card p-4 shadow-sm">

    <div class="d-flex justify-content-between mb-3">
        <input class="form-control w-50" placeholder="🔍 Tìm màu..."
               @bind="searchTerm" @bind:event="oninput" />

        <button class="btn btn-outline-primary" @onclick="ShowAddForm">
            ➕ Thêm mới
        </button>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>STT</th>
                <th>Màu</th>
                <th>Tên màu</th>
                <th>Mô tả</th>
                <th>Trạng thái</th>
                <th>Chức năng</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var (item, index) in PagedData.Select((v, i) => (v, i)))
            {
                <tr>
                    <td>@((CurrentPage - 1) * PageSize + index + 1)</td>

                    <!-- COLOR BOX -->
                    <td>
                        <div style="width:25px;height:25px;border-radius:50%;
                                    background:@item.Color;border:1px solid #ccc">
                        </div>
                    </td>

                    <td>@item.TenMau</td>
                    <td>@item.MoTa</td>

                    <td>
                        <span class="badge bg-@(item.TrangThai ? "success" : "secondary")">
                            @(item.TrangThai ? "Đang hoạt động" : "Ngừng")
                        </span>
                    </td>

                    <td>
                        <button class="btn btn-sm text-primary"
                                @onclick="() => ShowEditForm(item)">
                            ✏
                        </button>

                        <button class="btn btn-sm text-danger"
                                @onclick="() => AskDelete(item)">
                            🗑
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- PAGINATION -->
    <div class="d-flex justify-content-between mt-3">
        <div>
            Xem
            <select @onchange="OnPageSizeChanged">
                <option>5</option>
                <option>10</option>
            </select>
        </div>

        <div>
            @for (int i = 1; i <= TotalPages; i++)
            {
                <button class="btn btn-sm @(i == CurrentPage ? "btn-primary" : "btn-light")"
                        @onclick="() => ChangePage(i)">
                    @i
                </button>
            }
        </div>
    </div>
</div>

<!-- MODAL -->
<CreateOrUpdateMauSac FormData="FormData"
                      IsVisible="IsPopupVisible"
                      OnSubmit="SubmitForm"
                      OnClose="ClosePopup"
                      IsEdit="IsEdit" />

<DeleteMauSac Item="SelectedItem"
              IsVisible="IsConfirmVisible"
              OnDelete="ConfirmDelete"
              OnCancel="() => IsConfirmVisible = false" />

@code {
    private List<MauSacDTO> danhSach = new();
    private string searchTerm = "";
    private int CurrentPage = 1;
    private int PageSize = 5;

    private bool IsPopupVisible = false;
    private bool IsEdit = false;
    private MauSacDTO FormData = new();

    private bool IsConfirmVisible = false;
    private MauSacDTO SelectedItem;

    protected override async Task OnInitializedAsync()
    {
        danhSach = await mauSacService.GetAllAsync();
    }

    private List<MauSacDTO> Filtered =>
        danhSach.Where(x => string.IsNullOrEmpty(searchTerm)
        || x.TenMau.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

    private List<MauSacDTO> PagedData =>
        Filtered.Skip((CurrentPage - 1) * PageSize).Take(PageSize).ToList();

    private int TotalPages =>
        (int)Math.Ceiling((double)Filtered.Count / PageSize);

    private void ChangePage(int p) => CurrentPage = p;

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        PageSize = int.Parse(e.Value.ToString());
        CurrentPage = 1;
    }

    private void ShowAddForm()
    {
        IsEdit = false;
        FormData = new MauSacDTO { TrangThai = true, Color = "#000000" };
        IsPopupVisible = true;
    }

    private void ShowEditForm(MauSacDTO item)
    {
        IsEdit = true;
        FormData = item;
        IsPopupVisible = true;
    }

    private void ClosePopup() => IsPopupVisible = false;

    private async Task SubmitForm()
    {
        if (IsEdit)
            await mauSacService.UpdateAsync(FormData);
        else
            await mauSacService.CreateAsync(FormData);

        danhSach = await mauSacService.GetAllAsync();
        IsPopupVisible = false;
    }

    private void AskDelete(MauSacDTO item)
    {
        SelectedItem = item;
        IsConfirmVisible = true;
    }

    private async Task ConfirmDelete()
    {
        await mauSacService.DeleteAsync(SelectedItem.MauSacId);
        danhSach = await mauSacService.GetAllAsync();
        IsConfirmVisible = false;
    }
}