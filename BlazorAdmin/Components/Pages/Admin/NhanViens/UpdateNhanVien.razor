@page "/EditNhanVien/{Id:guid}"
@rendermode InteractiveServer

@using Data.Models
@using System.ComponentModel.DataAnnotations
@using BlazorAdmin.Service.IService

@inject INhanVienService NhanVienservice
@inject ITaiKhoanService taiKhoanService
@inject NavigationManager manager

<h3 class="mb-4">Chỉnh sửa nhân viên</h3>

<EditForm Model="Input" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <!-- Họ tên -->
    <div class="mb-3">
        <label class="form-label">Họ tên</label>
        <InputText class="form-control" @bind-Value="Input.HoTen" />
    </div>

    <!-- SĐT -->
    <div class="mb-3">
        <label class="form-label">Số điện thoại</label>
        <InputText class="form-control" @bind-Value="Input.SoDienThoai" />
    </div>

    <!-- Email -->
    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText class="form-control" @bind-Value="Input.Email" />
    </div>

    <!-- NGÀY SINH (FIX QUAN TRỌNG) -->
    <div class="mb-3">
        <label class="form-label">Ngày sinh</label>
        <InputDate class="form-control" @bind-Value="Input.NgaySinh" />
    </div>

    <!-- CHỨC VỤ -->
    <div class="mb-3">
        <label class="form-label">Chức vụ</label>

        <InputSelect class="form-select"
                     @bind-Value="Input.ChucVuId">

            <option value="">-- Chọn chức vụ --</option>

            <option value="11111111-1111-1111-1111-111111111111">
                Admin
            </option>

            <option value="22222222-2222-2222-2222-222222222222">
                Nhân viên
            </option>

        </InputSelect>
    </div>

    @if (nhanVien.TaiKhoan != null)
    {
        <!-- Username -->
        <div class="mb-3">
            <label class="form-label">Tên tài khoản</label>
            <InputText class="form-control" @bind-Value="Input.UserName" />
        </div>

        <!-- Password -->
        <div class="mb-3">
            <label class="form-label">Mật khẩu</label>

            <div class="input-group">
                <input class="form-control"
                       type="@(showPassword ? "text" : "password")"
                       @bind="Input.Password" />

                <button type="button"
                        class="btn btn-outline-secondary"
                        @onclick="TogglePassword">
                    <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                </button>
            </div>
        </div>

        <!-- Confirm Password -->
        <div class="mb-3">
            <label class="form-label">Nhập lại mật khẩu</label>

            <div class="input-group">
                <input class="form-control"
                       type="@(showPassword ? "text" : "password")"
                       @bind="Input.ConfirmPassword" />

                <button type="button"
                        class="btn btn-outline-secondary"
                        @onclick="TogglePassword">
                    <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                </button>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    <button type="submit" class="btn btn-success me-2">
        Lưu thay đổi
    </button>

    <button type="button"
            class="btn btn-danger"
            @onclick='() => manager.NavigateTo("/QuanLyNhanVien")'>
        Hủy thay đổi
    </button>
</EditForm>

@code {

    [Parameter]
    public Guid Id { get; set; }

    private NhanVien nhanVien = new()
    {
        TaiKhoan = new TaiKhoan()
    };

    private string errorMessage = "";
    private bool showPassword = false;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await NhanVienservice.GetByIdNhanVienAsync(Id);

            if (result != null)
            {
                nhanVien = result;
                nhanVien.TaiKhoan ??= new TaiKhoan();

                Input = new InputModel
                {
                    HoTen = nhanVien.HoTen,
                    SoDienThoai = nhanVien.SoDienThoai,
                    Email = nhanVien.Email,

                    // ⭐ FIX NGÀY SINH
                    NgaySinh = nhanVien.NgaySinh,

                    ChucVuId = nhanVien.ChucVuId.ToString(),

                    UserName = nhanVien.TaiKhoan?.Username ?? "",
                    Password = nhanVien.TaiKhoan?.Password ?? "",
                    ConfirmPassword = nhanVien.TaiKhoan?.Password ?? ""
                };
            }
            else
            {
                errorMessage = "Không tìm thấy nhân viên";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi tải dữ liệu: " + ex.Message;
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            errorMessage = "";

            if (Input.NgaySinh > DateTime.Now)
            {
                errorMessage = "Ngày sinh không hợp lệ";
                return;
            }

            if (Input.Password != Input.ConfirmPassword)
            {
                errorMessage = "Mật khẩu xác nhận không khớp";
                return;
            }

            var existingUser =
                await taiKhoanService.GetByUsernameAsync(Input.UserName);

            if (existingUser != null
                && existingUser.TaikhoanId != nhanVien.TaikhoanId)
            {
                errorMessage = "Tên đăng nhập đã tồn tại";
                return;
            }

            // UPDATE NHÂN VIÊN
            nhanVien.HoTen = Input.HoTen;
            nhanVien.SoDienThoai = Input.SoDienThoai;
            nhanVien.Email = Input.Email;

            // ⭐ FIX NGÀY SINH (QUAN TRỌNG NHẤT)
            nhanVien.NgaySinh = Input.NgaySinh ?? DateTime.Now;

            nhanVien.ChucVuId = Guid.Parse(Input.ChucVuId);
            nhanVien.NgayCapNhatCuoiCung = DateTime.Now;

            // UPDATE TÀI KHOẢN
            if (nhanVien.TaiKhoan != null)
            {
                nhanVien.TaiKhoan.Username = Input.UserName;
                nhanVien.TaiKhoan.Password = Input.Password;

                await taiKhoanService.UpdateTaiKhoanAsync(nhanVien.TaiKhoan);
            }

            await NhanVienservice.UpdateNhanVienAsync(nhanVien);

            manager.NavigateTo("/QuanLyNhanVien");
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi cập nhật: " + ex.Message;
        }
    }

    private sealed class InputModel
    {
        [Required]
        public string HoTen { get; set; } = string.Empty;

        [Required]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string SoDienThoai { get; set; } = string.Empty;

        // ⭐ FIX DATE
        [Required]
        public DateTime? NgaySinh { get; set; }

        [Required(ErrorMessage = "Vui lòng chọn chức vụ")]
        public string ChucVuId { get; set; } = string.Empty;

        [Required]
        public string UserName { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        [Required]
        [Compare("Password")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}