    private async Task ConfirmOrder()
    {
        if (CurrentOrder.Products.Count == 0)
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "warning",
                title = "Chưa thêm sản phẩm",
                text = "Đơn hàng chưa được thêm sản phẩm."
            });
            return;
        }

        if (CurrentOrder.ThongTinHoaDon.IsDelivery)
        {
            if (string.IsNullOrWhiteSpace(CurrentOrder.ThongTinHoaDon.TenNguoiNhan) || string.IsNullOrWhiteSpace(CurrentOrder.ThongTinHoaDon.Sdt))
            {
                await JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "warning",
                    title = "Dữ liệu chưa đủ!",
                    text = $"Chưa nhập thông tin người nhận",
                    confirmButtonText = "OK"
                });
                return;
            }

            if (!System.Text.RegularExpressions.Regex.IsMatch(CurrentOrder.ThongTinHoaDon.Sdt, @"^\d{9,11}$"))
            {
                await JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "warning",
                    title = "Dữ liệu chưa đủ!",
                    text = $"Số điện thoại không hợp lệ",
                    confirmButtonText = "OK"
                });
                return;
            }
            if (string.IsNullOrWhiteSpace(CurrentOrder.ThongTinHoaDon.TinhThanhPho) || string.IsNullOrWhiteSpace(CurrentOrder.ThongTinHoaDon.QuanHuyen) || string.IsNullOrWhiteSpace(CurrentOrder.ThongTinHoaDon.XaPhuongThiTran))
            {
                await JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "warning",
                    title = "Dữ liệu chưa đủ!",
                    text = $"Chưa chọn địa chỉ khu vực",
                    confirmButtonText = "OK"
                });
                return;
            }
            if (string.IsNullOrWhiteSpace(CurrentOrder.ThongTinHoaDon.DiaChiCuThe))
            {
                await JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "warning",
                    title = "Dữ liệu chưa đủ!",
                    text = $"Địa chỉ cụ thể chưa thêm",
                    confirmButtonText = "OK"
                });
                return;
            }
        }
        if (CustomerPay < TotalAmount)
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "warning",
                title = "Chưa đủ tiền!",
                text = $"Khách còn thiếu {FormatMoney(TotalAmount - CustomerPay)}",
                confirmButtonText = "OK"
            });
            return;
        }

        // ✅ Thành công


        if (CurrentOrder.ThongTinHoaDon.IsDelivery)
        {
            // Nếu chưa chọn khách hàng thì tạo khách mới
            if (CurrentOrder.Customer == null)
            {
                var khachhang = new KhachHang()
                {
                    HoTen = string.IsNullOrWhiteSpace(CurrentOrder.ThongTinHoaDon.TenNguoiNhan)
                            ? "Khách lẻ"
                            : CurrentOrder.ThongTinHoaDon.TenNguoiNhan,

                    SoDienThoai = CurrentOrder.ThongTinHoaDon.Sdt ?? ""
                };

                var result1 = await khachHangService.Create(khachhang);

                if (result1 != null)
                {
                    CurrentOrder.Customer = result1;
                }
            }

            // Sau khi chắc chắn có customer
            if (CurrentOrder.Customer != null)
            {
                var diachi = new Application.DTOs.DiaChiKhachHangDto()
                {
                    KhachHangId = CurrentOrder.Customer.KhachHangId,

                    ThanhPho = CurrentOrder.ThongTinHoaDon.TinhThanhPho,
                    QuanHuyen = CurrentOrder.ThongTinHoaDon.QuanHuyen,
                    PhuongXa = CurrentOrder.ThongTinHoaDon.XaPhuongThiTran,
                    DiaChiCuThe = CurrentOrder.ThongTinHoaDon.DiaChiCuThe
                };

                await DiaChiKhachHangService.CreateAsync(diachi);
            }
        }
        // ===== KIỂM TRA TỒN KHO TRƯỚC KHI TẠO HÓA ĐƠN =====
        foreach (var item in CurrentOrder.Products.ToList())
        {
            var giayChiTiet = await GiayChiTietService.GetByIdAsync(item.GiayChiTietId);

            if (giayChiTiet == null)
            {
                await JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "error",
                    title = "Lỗi",
                    text = $"Không tìm thấy sản phẩm {item.TenGiay}"
                });

                return;
            }

            // Kiểm tra số lượng tồn thực tế
            if (giayChiTiet.SoLuongCon < item.SoLuongDat)
            {
                // Nếu hết hàng thì xoá khỏi giỏ
                if (giayChiTiet.SoLuongCon <= 0)
                {
                    CurrentOrder.Products.Remove(item);
                }
                else
                {
                    item.SoLuongDat = giayChiTiet.SoLuongCon;
                }

                await JS.InvokeVoidAsync("Swal.fire", new
                {
                    icon = "warning",
                    title = "Không đủ hàng",
                    text = $"Sản phẩm {item.TenGiay} chỉ còn {giayChiTiet.SoLuongCon}"
                });

                StateHasChanged();
                return;
            }
        }
        if (CurrentOrder.Products.Count == 0)
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "warning",
                title = "Giỏ hàng trống",
                text = "Không còn sản phẩm hợp lệ để thanh toán"
            });

            return;
        }
        var nhanVienId = await JS.InvokeAsync<Guid>("localStorage.getItem", "currentId");
        Console.WriteLine(nhanVienId);

        var hoaDon = new HoaDon
        {
            NhanVienId = nhanVienId,

            KhachHangId = CurrentOrder.Customer?.KhachHangId ?? KhachLeId,

            // ===== THÔNG TIN NGƯỜI NHẬN =====
            TenNguoiNhan = string.IsNullOrWhiteSpace(CurrentOrder.ThongTinHoaDon.TenNguoiNhan)
                    ? "Khách lẻ"
                    : CurrentOrder.ThongTinHoaDon.TenNguoiNhan,

            SoDienThoai = CurrentOrder.ThongTinHoaDon.Sdt ?? "",

            DiaChi = CurrentOrder.ThongTinHoaDon.IsDelivery
                    ? $"{CurrentOrder.ThongTinHoaDon.DiaChiCuThe}, " +
                      $"{CurrentOrder.ThongTinHoaDon.XaPhuongThiTran}, " +
                      $"{CurrentOrder.ThongTinHoaDon.QuanHuyen}, " +
                      $"{CurrentOrder.ThongTinHoaDon.TinhThanhPho}"
                    : "",

            GhiChu = CurrentOrder.ThongTinHoaDon.GhiChu ?? "",

            TrangThai = "Hoàn thành",

            PhiShip = ShippingFee,

            TongTienSauKhiGiam = TotalAmount,
        };
        var result = await HoaDonService.Add(hoaDon);

        if (result != null)
        {

            foreach (var item in CurrentOrder.Products)
            {
                var hoadonchitiet = new HoaDonChiTiet()
                {
                    DonGia = (decimal)item.Gia, // giá 1 sản phẩm
                    Gia = (decimal)item.Gia * (decimal)item.SoLuongDat,
                    GiayChiTietId = item.GiayChiTietId,
                    HoaDonId = result.HoaDonId,
                    SoLuongSanPham = item.SoLuongDat,
                    TrangThai = true,
                };
                var result3 = await HoaDonChiTietService.Create(hoadonchitiet);
                if (result3 != null)
                {

                }
                else
                {
                    continue;
                }
            }
            foreach (var item2 in CurrentOrder.Products)
            {
                var giaychitiet = await GiayChiTietService.GetByIdAsync(item2.GiayChiTietId);

                giaychitiet.SoLuongCon -= item2.SoLuongDat;

                var result4 = await GiayChiTietService.UpdateAsync(item2.GiayChiTietId, giaychitiet);

                if (result4 == null)
                {
                    await JS.InvokeVoidAsync("Swal.fire", new
                    {
                        icon = "error",
                        title = "Lỗi cập nhật kho",
                        text = $"Không thể cập nhật sản phẩm {item2.TenGiay}"
                    });

                    return;
                }
            }
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "success",
                title = "Thành công",
                text = "Đơn hàng đã được ghi nhận."
            });

            // Xóa đơn hiện tại
            await RemoveOrder(CurrentOrderIndex);

            // Reset dữ liệu form
            CustomerPay = 0;
            DiscountPercent = 0;
            selectedVoucher = null;
            voucherError = "";

            Tinh = "";
            Huyen = "";
            Phuong = "";

            HuyenXa = new();
            XaPhuong = new();

            StateHasChanged();
        }
        else
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                icon = "warning",
                title = "Lỗi!",
                text = "Có lỗi khi lưu đơn hàng."
            });
        }



    }

