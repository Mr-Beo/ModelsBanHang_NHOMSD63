@page "/banhang"
@layout AdminLayout
@inject IXuLyDiaChi xuLyDiaChi
@inject IVoucherService voucherService
@inject IHoaDonService HoaDonService
@inject IKhachHangService khachHangService
@inject IDiaChiKhachHangService DiaChiKhachHangService
@inject IGiayChiTietService GiayChiTietService
@inject IHoaDonChiTietService HoaDonChiTietService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JS
@using API.Models.DTO.BanHang
@using API.Models.DTO
@using API.Models.DTO.HeThong
@inject NavigationManager Nav

<link href="css/BanHang.css" rel="stylesheet" />
<div class="sell-container">
    <!-- Tabs đơn hàng -->
    <div class="order-tabs">
        @foreach (var order in Orders.Select((value, index) => new { value, index }))
        {
            <div class="order-tab @(order.index == CurrentOrderIndex ? "active" : "")" @onclick="@(() => SwitchOrder(order.index))">
                Đơn hàng @(order.index + 1)
                @if (order.value.Products.Count > 0)
                {
                    <span class="order-qty-badge">@order.value.Products.Sum(p => p.SoLuongDat)</span>
                }
                <span class="close" @onclick="() => RemoveOrderSafe(order.index)">×</span>
            </div>
        }

        <button class="create-order-btn" @onclick="CreateOrder">+ Tạo đơn hàng</button>
    </div>
    @if (Orders.Count == 0)
    {
        <div class="empty-order-notice">
            Bạn chưa có đơn hàng nào.
            <button class="create-order-btn" @onclick="CreateOrder">+ Tạo đơn hàng đầu tiên</button>
        </div>
    }

    <!-- Thanh công cụ sản phẩm -->
    @if (CurrentOrder != null)
    {
        <div class="order-actions">
            <div class="order-list-title">Sản phẩm</div>

            <div class="order-actions-buttons">

                <button class="qr-btn" @onclick="ScanQRCode">📷 Quét QR sản phẩm</button>

                <button class="add-btn" @onclick="() => IsProductModalVisible = true">Thêm sản phẩm</button>
                <ProductSelect Visible="@IsProductModalVisible"
                               OnAddProduct="HandleAddProduct"
                               OnClose="@(() => IsProductModalVisible = false)" />
            </div>
        </div>

    }
    @if (ShowQrScanner)
    {
        <div class="modal-overlay">
            <div class="modal-content">
                <div id="qr-reader"></div>

                <button class="btn btn-danger"
                        @onclick="CloseQrScanner">
                    Đóng
                </button>
            </div>
        </div>
    }
    @if (CurrentOrder != null)
    {
        <!-- Danh sách sản phẩm trong đơn hàng -->
        <div class="order-list @OrderListClass">
            @if (CurrentOrder?.Products.Count == 0)
            {
                <div>Chưa có sản phẩm nào trong đơn hàng</div>
            }
            else
            {
                @foreach (var product in CurrentOrder.Products)
                {
                    <div class="order-item">
                        <img src="@GetFullImageUrl(product.AnhGiay)"
                             class="order-img"
                             loading="lazy"
                             onerror="this.onerror=null;this.src='/images/no-image.png';" />
                        <div class="item-info">
                            <div class="order-name">@product.TenGiay</div>
                            <div class="order-price">
                                <span class="old-price">@FormatMoney(product.GiaGoc)</span>
                                <span class="new-price">@FormatMoney(product.Gia)</span>
                            </div>
                            <div class="order-size">Size: @product.size</div>
                        </div>
                        <div class="order-qty">
                            <button class="decrease-btn" @onclick="() => DecreaseQuantity(product)">-</button>
                            <input class="qty-input" type="number" value="@product.SoLuongDat" readonly />
                            <button class="increase-btn" @onclick="() => IncreaseQuantity(product)">+</button>
                        </div>
                        <div class="order-total">@FormatMoney(product.SoLuongDat * (int)product.Gia)</div>
                        <button class="order-remove" @onclick="() => RemoveProduct(product)">×</button>
                    </div>
                }

            }
        </div>
    }

    <!-- Khách hàng -->
    @if (CurrentOrder != null)
    {
        <div class="customer-header">
            <span class="customer-title">
                Khách hàng: <span class="customer-name">@(CurrentOrder?.Customer?.HoTen ?? "Khách lẻ") </span>
                @if (CurrentOrder?.Customer != null && CurrentOrder.ThongTinHoaDon.IsDelivery)
                {
                    <button type="button" class="address-change-btn" @onclick="() => IsAddressModalVisible = true"
                            style="margin-left:8px; background:#ff9800; color:#fff; border:none; border-radius:4px; padding:4px 8px; font-size:12px; cursor:pointer;">
                        Chọn địa chỉ
                    </button>
                    <AddressSelect Visible="@IsAddressModalVisible"
                                   OnAddressSelected="HandleAddressSelected"
                                   OnClose="@(() => IsAddressModalVisible = false)" />
                }
            </span>
            <button class="choose-customer-btn" @onclick="() => IsCustomerModalVisible = true">+ CHỌN KHÁCH HÀNG</button>
            <CustomerSelect Visible="@IsCustomerModalVisible"
                            OnCustomerSelected="HandleCustomerSelected"
                            OnClose="@(() => IsCustomerModalVisible = false)" />
            @if (CurrentOrder?.Customer != null)
            {
                <button class="reset-customer-btn" @onclick="@Khachle"
                        style=" margin-left:8px; background:#e0e0e0; color:#333; border:none; border-radius:6px; padding:8px 16px; cursor:pointer; font-weight:500;height:40px;">
                    Đổi về khách lẻ
                </button>
            }
        </div>

    }



    <!-- Footer đặt hàng -->
    @if (CurrentOrder != null)
    {


        <div class="order-footer">
            @if (CurrentOrder.ThongTinHoaDon.IsDelivery)
            {

                <div class="customer-info">
                    <div class="customer-info-row">
                        <div>
                            <label>Tên người nhận</label>
                            <input type="text" class="receiver-name-input" @bind="CurrentOrder.ThongTinHoaDon.TenNguoiNhan" />
                        </div>
                        <div>
                            <label>Số điện thoại</label>
                            <input type="text" class="receiver-phone-input" @bind="CurrentOrder.ThongTinHoaDon.Sdt" />
                        </div>
                    </div>
                    <div class="customer-info-row">
                        <div class="customer-info-row">
                            <div>
                                <label for="TinhThanh">Tỉnh/Thành phố</label>
                                <input id="TinhThanh" @onchange="OnTinhChanged"
                                       list="Tinh"
                                       value="@Tinh"
                                       class="province-input" />
                                <datalist id="Tinh">
                                    @foreach (var t in TinhThanh)
                                    {
                                        <option value="@t.Ten" />
                                    }
                                </datalist>

                            </div>
                            <div>
                                <label for="QuanHuyen">Quận/Huyện</label>
                                <input id="QuanHuyen"
                                       @onchange="OnHuyenChanged"
                                       list="Quan"
                                       value="@Huyen"
                                       disabled="@string.IsNullOrEmpty(Tinh)"
                                       class="province-input" />
                                <datalist id="Quan">
                                    @foreach (var h in HuyenXa)
                                    {
                                        <option value="@h.Ten" />
                                    }
                                </datalist>
                            </div>
                            <div>
                                <label for="XaPhuongThiTran">Xã/Phường/Thị trấn</label>
                                <input id="XaPhuongThiTran"
                                       @onchange="OnXaPhuongChanged"
                                       list="XaPhuong"
                                       value="@Phuong"
                                       disabled="@string.IsNullOrEmpty(Huyen)"
                                       class="province-input" />
                                <datalist id="XaPhuong">
                                    @foreach (var x in XaPhuong)
                                    {
                                        <option value="@x.Ten" />
                                    }
                                </datalist>
                            </div>
                        </div>
                    </div>
                    <div class="customer-info-row">
                        <div style="flex:2; position:relative;">
                            <label>Địa chỉ cụ thể</label>
                            <input type="text" class="address-detail-input" @bind="CurrentOrder.ThongTinHoaDon.DiaChiCuThe" placeholder="Địa chỉ cụ thể">
                        </div>
                        <div style="flex:1;">
                            <label>Ghi chú</label>
                            <input type="text" class="note-input" @bind="CurrentOrder.ThongTinHoaDon.GhiChu" placeholder="Ghi chú">
                        </div>
                    </div>
                </div>
            }

        <div class="order-info">
            <div style="text-align: right; margin-bottom: 12px;">
                <label for="GiaoHang">Giao hàng</label>
                <input id="GiaoHang" type="checkbox" class="delivery-toggle" @bind="CurrentOrder.ThongTinHoaDon.IsDelivery" />
            </div>

            <div class="voucher-area">
                <input class="voucher-code-input"
                       placeholder="Nhập mã voucher..."
                       @bind="voucherCode"
                       @bind:event="oninput"
                       @onchange="OnVoucherCodeChange"
                       disabled="@(CurrentOrder?.Products == null || CurrentOrder.Products.Count == 0)" />
                <button type="button"
                        class="choose-voucher-btn"
                        @onclick="() => IsVoucherModalVisible = true">

                    @(selectedVoucher != null
                                        ? $"Voucher: {selectedVoucher.TenVoucher}"
                                        : "🎁 Chọn voucher")
                </button>

                    <input disabled
                           type="text"
                           value="@($"{DiscountPercent} %")"
                           class="discount-input" />

                @if (!string.IsNullOrEmpty(voucherError))
                    {
                        <div style="color:red;margin-top:6px">
                            @voucherError
                        </div>
                    }
                </div>
                @if (IsVoucherModalVisible)
                {
                    <div class="voucher-modal-overlay">

                        <div class="voucher-modal">

                            <div class="voucher-header">
                                <h4>Danh sách voucher</h4>

                                <button class="close-btn"
                                        @onclick="() => IsVoucherModalVisible = false">
                                    ×
                                </button>
                            </div>

                            <div class="voucher-list">

                                @foreach (var voucher in vouchers.Where(x => x.TrangThai))
                                {
                                    bool duDieuKien = Subtotal >= voucher.DieuKienToiThieu;

                                    <div class="voucher-card
                                                             @(duDieuKien ? "" : "disabled")
                                                             @(selectedVoucher?.VoucherId == voucher.VoucherId ? "active" : "")">

                                        <div class="voucher-info">
                                            <div class="voucher-name">
                                                @voucher.TenVoucher
                                            </div>

                                            <div class="voucher-condition">
                                                Đơn tối thiểu:
                                                @FormatMoney(voucher.DieuKienToiThieu)
                                            </div>

                                            <div class="voucher-discount">
                                                @if (voucher.PhanTram > 0)
                                                {
                                                    <span>Giảm @voucher.PhanTram %</span>
                                                }
                                                else
                                                {
                                                    <span>
                                                        Giảm @FormatMoney(voucher.SoTienGiam)
                                                    </span>
                                                }
                                        </div>
                                    </div>

                                    <button class="select-voucher-btn"
                                            disabled="@(!duDieuKien)"
                                            @onclick="() => ToggleVoucher(voucher)">

                                        @(selectedVoucher?.VoucherId == voucher.VoucherId
                                                                        ? "Huỷ"
                                                                        : "Chọn")
                            </button>

                                    </div>
                                                }

                            </div>

                        </div>
                    </div>
                }
                <div class="order-summary">
                    <div class="order-row">
                        <span>Tiền hàng</span>
                        <span>@FormatMoney(Subtotal)</span>
                    </div>
                    @if (CurrentOrder != null && CurrentOrder.ThongTinHoaDon.IsDelivery)
                    {
                        <div class="order-row">
                            <span>Phí vận chuyển</span>
                            <span>@FormatMoney(ShippingFee)</span>
                        </div>
                    }
                    <div class="order-row">
                        <span>Giảm giá</span>
                        <span>@FormatMoney(DiscountAmount)</span>
                    </div>
                    <div class="order-row total">
                        <span>Tổng số tiền</span>
                        <span>@FormatMoney(TotalAmount)</span>
                    </div>
                    <div class="order-row">
                        <span>Khách thanh toán:</span>
                        <input class="pay-input" type="text" @bind="CustomerPay" />
                    </div>
                    <div class="order-row deficit">
                        <span>Số tiền phải trả</span>
                        <span>@DeficitAmount</span>
                    </div>
                    <button class="confirm-btn" @onclick="ConfirmOrder">XÁC NHẬN ĐẶT HÀNG</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool IsVoucherModalVisible = false;
    private string BaseApiUrl = "https://localhost:7246";
    private string OrderListClass => CurrentOrder?.Products?.Count == 0 ? "empty" : "";
    // 📦 Dữ liệu đơn hàng

    private List<Order> Orders = new();
    private int CurrentOrderIndex = 0;
    private Order? CurrentOrder =>
    Orders != null && Orders.Count > 0 && CurrentOrderIndex < Orders.Count
    ? Orders[CurrentOrderIndex]
    : null;

    private string voucherCode = "";
    private async Task OnVoucherCodeChange(ChangeEventArgs e)
    {
        voucherError = "";
        selectedVoucher = null;
        DiscountPercent = 0;

        voucherCode = e.Value?.ToString()?.Trim();

        // ❌ CHẶN NẾU CHƯA CÓ SẢN PHẨM
        if (CurrentOrder?.Products == null || CurrentOrder.Products.Count == 0)
        {
            voucherError = "Vui lòng chọn sản phẩm trước khi nhập voucher";
            return;
        }

        if (string.IsNullOrEmpty(voucherCode))
            return;

        var voucher = vouchers.FirstOrDefault(v =>
            v.TenVoucher.Equals(voucherCode, StringComparison.OrdinalIgnoreCase));

        if (voucher == null)
        {
            voucherError = "Mã voucher không tồn tại";
            return;
        }

        if (!voucher.TrangThai)
        {
            voucherError = "Voucher không còn hiệu lực";
            return;
        }

        if (Subtotal < voucher.DieuKienToiThieu)
        {
            voucherError = $"Đơn tối thiểu {FormatMoney(voucher.DieuKienToiThieu)}";
            return;
        }

        ApplyVoucher(voucher);
    }
    private void ApplyVoucher(Voucher voucher)
    {
        selectedVoucher = voucher;
        voucherError = "";
        voucherCode = voucher.TenVoucher;

        DiscountPercent = voucher.PhanTram > 0
            ? voucher.PhanTram
            : 0;

        IsVoucherModalVisible = false;

        StateHasChanged();
    }
    // 💰 Tính toán đơn hàng
    private float DiscountPercent { get; set; } = 0;
    private float _CustomerPay;
    private float CustomerPay
    {
        get => _CustomerPay;
        set
        {
            FormatMoney(DeficitAmount);
            _CustomerPay = value;
        }
    }


    private float Subtotal => CurrentOrder?.Products?.Sum(p => p.SoLuongDat * p.Gia) ?? 0f;
    private float ShippingFee
    {
        get
        {
            if (CurrentOrder == null || !CurrentOrder.ThongTinHoaDon.IsDelivery)
                return 0;

            var tinh = CurrentOrder.ThongTinHoaDon.TinhThanhPho?.Trim().ToLower();

            if (string.IsNullOrEmpty(tinh))
                return 0;

            // ===== Hà Nội freeship =====
            if (tinh.Contains("hà nội") || tinh.Contains("ha noi"))
                return 0;

            // ===== Miền Bắc =====
            var mienBac = new List<string>
        {
            "hải phòng", "hai phong",
            "quảng ninh", "bac ninh",
            "bắc giang", "thai nguyen",
            "nam định", "ninh bình",
            "hưng yên", "hải dương",
            "vĩnh phúc", "phú thọ"
        };

            // ===== Miền Trung =====
            var mienTrung = new List<string>
        {
            "đà nẵng", "da nang",
            "nghệ an", "hà tĩnh",
            "quảng bình", "quảng trị",
            "huế", "thừa thiên huế",
            "quảng nam", "quảng ngãi",
            "bình định", "phú yên",
            "khánh hòa"
        };

            // ===== Miền Nam =====
            var mienNam = new List<string>
        {
            "hồ chí minh", "ho chi minh",
            "cần thơ", "đồng nai",
            "bình dương", "long an",
            "tiền giang", "vũng tàu",
            "an giang", "cà mau"
        };

            if (mienBac.Any(x => tinh.Contains(x)))
                return 20000;

            if (mienTrung.Any(x => tinh.Contains(x)))
                return 30000;

            if (mienNam.Any(x => tinh.Contains(x)))
                return 40000;

            // mặc định
            return 35000;
        }
    }
    private float DiscountAmount => CurrentOrder == null ? 0 : (Subtotal * DiscountPercent) / 100f;

    private float TotalAmount => CurrentOrder == null ? 0 : Subtotal + ShippingFee - DiscountAmount;

    private float DeficitAmount => CurrentOrder == null ? 0 : TotalAmount - CustomerPay;

    private List<DiaChi> TinhThanh = new();
    private List<DiaChi> HuyenXa = new();
    private List<DiaChi> XaPhuong = new();
    private List<Voucher> vouchers = new();
    private Voucher selectedVoucher = new();
    private Guid? KhachLeId;
    private bool ShowQrScanner = false;
    private bool StartScannerAfterRender = false;
    private async Task ToggleVoucher(Voucher voucher)
    {
        voucherError = "";
        voucherCode = voucher.TenVoucher;
        // CLICK LẦN 2 => HỦY
        if (selectedVoucher?.VoucherId == voucher.VoucherId)
        {
            selectedVoucher = null;
            DiscountPercent = 0;
            voucherCode = "";
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                toast = true,
                position = "top-end",
                icon = "info",
                title = "Đã huỷ voucher",
                showConfirmButton = false,
                timer = 1500
            });

            StateHasChanged();
            return;
        }

        // VALIDATE
        if (Subtotal < voucher.DieuKienToiThieu)
        {
            voucherError = $"Cần tối thiểu {FormatMoney(voucher.DieuKienToiThieu)}";
            return;
        }

        // CHỌN VOUCHER
        selectedVoucher = voucher;

        if (voucher.PhanTram > 0)
        {
            DiscountPercent = voucher.PhanTram;
        }
        else
        {
            DiscountPercent = 0;
        }

        IsVoucherModalVisible = false;

        await JS.InvokeVoidAsync("Swal.fire", new
        {
            toast = true,
            position = "top-end",
            icon = "success",
            title = "Áp dụng voucher thành công",
            showConfirmButton = false,
            timer = 2000
        });

        StateHasChanged();
    }
    // 🛒 Hành động
    private async void CreateOrder()
    {

        if (Orders.Count >= 5)
        {
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                toast = true,
                position = "top-end",
                icon = "info",
                title = "Bạn đã tạo tối đa 5 đơn hàng.",
                showConfirmButton = false,
                timer = 3000,
                timerProgressBar = true
            });
            return;
        }
        Orders.Add(new Order());
        CurrentOrderIndex = Orders.Count - 1;
        StateHasChanged();
        await SaveOrdersToStorage();
    }

    private async Task RemoveOrder(int index)
    {
        if (Orders.Count < 1)
        {
            Orders = new() { new Order() };
            CurrentOrderIndex = 0;
            await SaveOrdersToStorage();
            return;
        }

        Orders.RemoveAt(index);

        if (index <= CurrentOrderIndex && CurrentOrderIndex > 0)
        {
            CurrentOrderIndex--;
        }

        if (CurrentOrderIndex >= Orders.Count)
        {
            CurrentOrderIndex = Orders.Count - 1;
        }
        await SaveOrdersToStorage();
    }

    private bool IsRemovingOrder = false;

    private async Task RemoveOrderSafe(int index)
    {
        var result = await JS.InvokeAsync<SwalResult>("Swal.fire", new
        {
            title = "Xác nhận xóa đơn hàng",
            text = "Bạn có chắc muốn xác nhận đơn hàng này?",
            icon = "question",
            showCancelButton = true,
            confirmButtonText = "Xác nhận",
            cancelButtonText = "Huỷ"
        });

        if (result.IsConfirmed)
        {
            if (IsRemovingOrder) return;
            IsRemovingOrder = true;

            RemoveOrder(index);
            await Task.Delay(200);
            IsRemovingOrder = false;
        }
    }


    private async Task SwitchOrder(int index)
    {
        CurrentOrderIndex = index;


        Tinh = CurrentOrder.ThongTinHoaDon.TinhThanhPho;
        Huyen = CurrentOrder.ThongTinHoaDon.QuanHuyen;
        Phuong = CurrentOrder.ThongTinHoaDon.XaPhuongThiTran;

        var tinh = TinhThanh.FirstOrDefault(t => t.Ten == Tinh);
        HuyenXa = tinh?.Con ?? new();

        var huyen = HuyenXa.FirstOrDefault(h => h.Ten == Huyen);
        XaPhuong = huyen?.Con ?? new();
        await SaveOrdersToStorage();
    }

    private async void IncreaseQuantity(GiayChiTietDTO product)
    {
        product.SoLuongDat++;
        if (product.SoLuongDat > product.SoLuongCon)
        {
            product.SoLuongDat = product.SoLuongCon;
            await JS.InvokeVoidAsync("Swal.fire", new
            {
                toast = true,
                position = "top-end",
                icon = "info",
                title = "Số lượng sản phẩm tối đa",
                showConfirmButton = false,
                timer = 3000,
                timerProgressBar = true
            });
        }
        await SaveOrdersToStorage();
    }

    private async Task DecreaseQuantity(GiayChiTietDTO product)
    {
        product.SoLuongDat--;
        if (product.SoLuongDat < 1) RemoveProduct(product);
        if (CurrentOrder.Products.Count == 0)
        {
            selectedVoucher = null;
            DiscountPercent = 0;
            voucherCode = "";
            voucherError = "";
        }
        await SaveOrdersToStorage();


    }

    private async Task RemoveProduct(GiayChiTietDTO product)
    {
        CurrentOrder.Products.Remove(product);
        await SaveOrdersToStorage();
    }


    private System.Threading.Timer? OrderCleanupTimer;
    protected override void OnInitialized()
    {
        Orders ??= new();
        OrderCleanupTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                var now = DateTime.Now;
                Orders.RemoveAll(o => (now - o.ThoiGianTao).TotalMinutes >= 10);
                if (CurrentOrderIndex >= Orders.Count)
                {
                    CurrentOrderIndex = Orders.Count - 1;
                }
                StateHasChanged();
            });
        }, null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
    }



    private async void ScanQRCode()
    {
        ShowQrScanner = true;
        StartScannerAfterRender = true;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (StartScannerAfterRender)
        {
            StartScannerAfterRender = false;

            await JS.InvokeVoidAsync(
                "startQrScanner",
                DotNetObjectReference.Create(this));
        }
    }
    [JSInvokable]
    public async Task ReceiveQRCode(string qrContent)
    {
        if (!Guid.TryParse(qrContent, out Guid giayChiTietId))
        {
            await JS.InvokeVoidAsync("alert",
                "QR không hợp lệ");
            return;
        }

        var product =
            await GiayChiTietService.GetByIdAsync(giayChiTietId);

        if (product == null)
        {
            await JS.InvokeVoidAsync("alert",
                "Không tìm thấy sản phẩm");
            return;
        }

        await HandleAddProduct(product);

        ShowQrScanner = false;

        StateHasChanged();

        await JS.InvokeVoidAsync("Swal.fire", new
        {
            icon = "success",
            title = "Đã thêm sản phẩm"
