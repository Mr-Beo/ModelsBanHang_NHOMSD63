    string voucherError = "";
    async Task OnVoucherChange(ChangeEventArgs e)
    {
        string selectedvoucher = e.Value?.ToString()?.Trim();

        var voucher = vouchers.FirstOrDefault(v => v.TenVoucher == selectedvoucher);

        // reset
        voucherError = "";
        DiscountPercent = 0;
        selectedVoucher = null;

        if (voucher == null)
        {
            voucherError = "Voucher không tồn tại";
            StateHasChanged();
            return;
        }

        if (!voucher.TrangThai)
        {
            voucherError = "Phiếu giảm giá đã hết hạn hoặc không còn hiệu lực.";
            return;
        }

        if (Subtotal < voucher.DieuKienToiThieu)
        {
            voucherError = $"Cần tối thiểu {FormatMoney(voucher.DieuKienToiThieu)}";
            return;
        }

        if (voucher.PhanTram <= 0 && voucher.SoTienGiam <= 0)
        {
            voucherError = "Voucher không hợp lệ";
            return;
        }

        selectedVoucher = voucher;

        if (voucher.PhanTram > 0)
        {
            DiscountPercent = voucher.PhanTram;
        }
        else
        {
            DiscountPercent = 0;
        }

        StateHasChanged();
    }
    private async Task SaveOrdersToStorage()
    {
        await LocalStorage.SetItemAsync("banhang_orders", Orders);
        await LocalStorage.SetItemAsync("banhang_currentIndex", CurrentOrderIndex);
    }
    private string GetFullImageUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "/images/no-image.png";

        if (path.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return path;

        if (!path.StartsWith("/"))
            path = "/" + path;

        return $"{BaseApiUrl.TrimEnd('/')}{path}";
    }
