        /* checkbox đẹp hơn */
        .select-product-checkbox input {
            width: 20px;
            height: 20px;
            accent-color: #ff9800;
            cursor: pointer;
        }

    /* căn giữa phần info */
    .item-info {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center; /* căn giữa dọc */
