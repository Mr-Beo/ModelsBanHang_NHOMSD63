    }

    /* căn giữa bên phải */
    .product-right {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* tổng tiền căn giữa */
    .order-total {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 170px;
    }
</style>
